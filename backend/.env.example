# Compte de service Firebase (JSON) : Console Firebase > Paramètres du projet > Comptes de service > Générer une nouvelle clé privée
# Option A : chemin vers le fichier (recommandé)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# Option B : variable système pointant vers le JSON (voir doc Google)
# GOOGLE_APPLICATION_CREDENTIALS=C:\chemin\vers\serviceAccount.json

# Optionnel : nom de la collection Firestore (défaut : users)
# FIRESTORE_USERS_COLLECTION=users

SESSION_SECRET=remplace_par_une_chaine_longue_et_aleatoire

# Gmail : GMAIL_USER = ton adresse complète. GMAIL_PASS = mot de passe D'APPLICATION (16 lettres),
# pas ton mot de passe habituel. Google : compte > Sécurité > Validation en 2 étapes activée,
# puis « Mots de passe des applications » : https://myaccount.google.com/apppasswords
# Colle le mot de passe sans espaces. Si le mot de passe contient # ou $, mets la valeur entre guillemets.
GMAIL_USER=ton.email@gmail.com
GMAIL_PASS=abcdefghijklmnop
